+                                         unsigned int flags,
+                                         struct page **pages,
+                                         struct vm_area_struct **vmas)
+    {
+        int write = !!(flags & FOLL_WRITE);
+        int force = !!(flags & FOLL_FORCE);
 
-            return get_user_pages(start, nr_pages, flags, pages, vmas);
-        }
