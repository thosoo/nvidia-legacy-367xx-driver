From 5b16f9481b2805b3b248b8b48bd9e307064069a9 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Fri, 11 Aug 2023 10:27:27 +0200
Subject: [PATCH] backport get_user_pages API migration for 367.134
Origin: Debian nvidia-graphics-drivers 390-series packaging, consolidated from
 the 418.30, 520.56.06, 525.53, and 535.86.05 GUP compatibility patches and
 rebased onto NVIDIA 367.134.
Description: Select one local and one remote get_user_pages signature by
 conftest, convert 367.134 call sites to pass FOLL_* flags, preserve explicit
 mm ownership for remote wrappers, pass NULL only for legacy task_struct
 arguments, and support kernels where the vmas argument has been removed.

--- a/common/inc/nv-mm.h
+++ b/common/inc/nv-mm.h
@@ -27,153 +27,98 @@
 
 /* get_user_pages
  *
- * The 8-argument version of get_user_pages was deprecated by commit 
- * (2016 Feb 12: cde70140fed8429acf7a14e2e2cbd3e329036653)for the non-remote case 
- * (calling get_user_pages with current and current->mm).
- *
- * Completely moved to the 6 argument version of get_user_pages -
- * 2016 Apr 4: c12d2da56d0e07d230968ee2305aaa86b93a6832
- *
- * write and force parameters were replaced with gup_flags by - 
- * 2016 Oct 12: 768ae309a96103ed02eb1e111e838c87854d8b51
- *
- * A 7-argument version of get_user_pages was introduced into linux-4.4.y by
- * commit 8e50b8b07f462ab4b91bc1491b1c91bd75e4ad40 which cherry-picked the
- * replacement of the write and force parameters with gup_flags
- *
+ * NVIDIA 367.134 call sites keep the historical wrapper arguments
+ * (start, nr_pages, write/force-or-flags, pages, vmas). The conftest macros
+ * below select the exact kernel signature and the wrappers preserve page
+ * pinning semantics: write maps to FOLL_WRITE and force maps to FOLL_FORCE.
+ *
+ * Relevant API transitions:
+ * - cde70140fed8: removed task_struct/mm from non-remote get_user_pages()
+ * - 768ae309a961/9beae1ea8930: replaced write/force booleans with gup_flags
+ * - 5b56d49fc31d: added locked to get_user_pages_remote()
+ * - 64019a2e467a: removed task_struct from get_user_pages_remote()
+ * - 7bbf9c8c99/a4bde14d549: removed vmas from local/remote GUP APIs
  */
 
