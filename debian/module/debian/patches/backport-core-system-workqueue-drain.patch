+typedef enum
+{
+    NV_WQ_UNINITIALIZED = 0,
+    NV_WQ_INITIALIZING,
+    NV_WQ_RUNNING,
+    NV_WQ_DRAINING,
+    NV_WQ_STOPPING,
+    NV_WQ_STOPPED,
+} nv_linux_workqueue_state_t;
+
+static DEFINE_SPINLOCK(nv_linux_workqueue_lock);
+static LIST_HEAD(nv_linux_workqueue_items);
+static DECLARE_WAIT_QUEUE_HEAD(nv_linux_workqueue_worker_wait);
+static DECLARE_WAIT_QUEUE_HEAD(nv_linux_workqueue_flush_wait);
+static DECLARE_WAIT_QUEUE_HEAD(nv_linux_workqueue_shutdown_wait);
+static struct task_struct *nv_linux_workqueue_thread;
+static nv_linux_workqueue_state_t nv_linux_workqueue_state = NV_WQ_UNINITIALIZED;
+static NvU64 nv_linux_workqueue_next_sequence;
+static NvU64 nv_linux_workqueue_completed_sequence;
+static NvU64 nv_linux_workqueue_generation;
+
+static NvBool nv_linux_workqueue_has_work(void)
+{
+    NvBool ret;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    ret = !list_empty(&nv_linux_workqueue_items);
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    return ret;
+}
+
+static NvBool nv_linux_workqueue_barrier_done(NvU64 barrier)
+{
+    NvBool ret;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    ret = (nv_linux_workqueue_completed_sequence >= barrier);
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    return ret;
+}
+
+static NvBool nv_linux_workqueue_initializing_done(void)
+{
+    NvBool ret;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    ret = (nv_linux_workqueue_state != NV_WQ_INITIALIZING);
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    return ret;
+}
+
+static NvBool nv_linux_workqueue_generation_done(NvU64 generation)
+{
+    NvBool ret;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    ret = (nv_linux_workqueue_generation != generation);
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    return ret;
+}
+
+static int nv_linux_workqueue_main(void *arg)
+{
+    nv_task_t *task;
+    void *owned_allocation;
+    NvU64 complete_sequence;
+    unsigned long flags;
+
+    for (;;)
+    {
+        int wait_rc;
+
+        wait_rc = wait_event_interruptible(nv_linux_workqueue_worker_wait,
+            kthread_should_stop() || nv_linux_workqueue_has_work());
+
+        if (kthread_should_stop())
+            break;
+
+        if (wait_rc != 0)
+        {
+            /*
+             * Unexpected interruption of the idle kernel worker wait. Yield,
+             * then retry without consuming or losing queued work; the locked
+             * predicate is rechecked before sleeping again.
+             */
+            cond_resched();
+            continue;
+        }
+
+        for (;;)
+        {
+            spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+            if (list_empty(&nv_linux_workqueue_items))
+            {
+                spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+                break;
+            }
+
+            task = list_first_entry(&nv_linux_workqueue_items,
+                                    nv_task_t, entry);
+            list_del_init(&task->entry);
+            task->running_sequence = task->queued_sequence;
+            task->queued = NV_FALSE;
+            task->running = NV_TRUE;
+            spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+#if (NV_INIT_WORK_ARGUMENT_COUNT == 2)
+            task->handler(task);
+#else
+            task->handler(task->handler_data);
+#endif
+
+            spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+            complete_sequence = task->running_sequence;
+            owned_allocation = task->owned_allocation;
+            task->running = NV_FALSE;
+            if (owned_allocation != NULL)
+                task->owned_allocation = NULL;
+            spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+            if (owned_allocation != NULL)
+                os_free_mem(owned_allocation);
+
+            spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+            if (complete_sequence > nv_linux_workqueue_completed_sequence)
+                nv_linux_workqueue_completed_sequence = complete_sequence;
+            spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+            wake_up_all(&nv_linux_workqueue_flush_wait);
+        }
+    }
+
+    wake_up_all(&nv_linux_workqueue_flush_wait);
+
+    return 0;
+}
+
+int nv_linux_workqueue_init(void)
+{
+    struct task_struct *thread;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    if ((nv_linux_workqueue_state == NV_WQ_INITIALIZING) ||
+        (nv_linux_workqueue_state == NV_WQ_RUNNING) ||
+        (nv_linux_workqueue_state == NV_WQ_DRAINING) ||
+        (nv_linux_workqueue_state == NV_WQ_STOPPING))
+    {
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        return -EBUSY;
+    }
+
+    INIT_LIST_HEAD(&nv_linux_workqueue_items);
+    nv_linux_workqueue_thread = NULL;
+    nv_linux_workqueue_next_sequence = 0;
+    nv_linux_workqueue_completed_sequence = 0;
+    nv_linux_workqueue_state = NV_WQ_INITIALIZING;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    thread = kthread_create_on_node(nv_linux_workqueue_main,
+                                    NULL,
+                                    NUMA_NO_NODE,
+                                    "nvidia-wq");
+    if (IS_ERR(thread))
+    {
+        int rc = PTR_ERR(thread);
+
+        spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+        nv_linux_workqueue_thread = NULL;
+        nv_linux_workqueue_generation++;
+        nv_linux_workqueue_state = NV_WQ_STOPPED;
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        wake_up_all(&nv_linux_workqueue_shutdown_wait);
+        return rc;
+    }
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    nv_linux_workqueue_thread = thread;
+    nv_linux_workqueue_state = NV_WQ_RUNNING;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    wake_up_process(thread);
+    wake_up_all(&nv_linux_workqueue_shutdown_wait);
+    return 0;
+}
+
+int nv_linux_workqueue_schedule(nv_task_t *task)
+{
+    unsigned long flags;
+    int accepted = 0;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    if ((nv_linux_workqueue_thread != NULL) &&
+        ((nv_linux_workqueue_state == NV_WQ_RUNNING) ||
+         (nv_linux_workqueue_state == NV_WQ_DRAINING)) &&
+        !task->queued && (task->requeueable || (task->queued_sequence == 0)))
+    {
+        task->queued_sequence = ++nv_linux_workqueue_next_sequence;
+        list_add_tail(&task->entry, &nv_linux_workqueue_items);
+        task->queued = NV_TRUE;
+        accepted = 1;
+    }
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    if (accepted)
+        wake_up(&nv_linux_workqueue_worker_wait);
+
+    return accepted;
+}
+
+static int nv_linux_workqueue_flush_once(void)
+{
+    NvU64 barrier;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    if (current == nv_linux_workqueue_thread)
+    {
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        nv_printf(NV_DBG_ERRORS,
+                  "NVRM: nv_linux_workqueue_flush: called from worker thread\n");
+        return -EDEADLK;
+    }
+    barrier = nv_linux_workqueue_next_sequence;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    wait_event(nv_linux_workqueue_flush_wait,
+        nv_linux_workqueue_barrier_done(barrier));
+
+    return 0;
+}
+
+int nv_linux_workqueue_flush(void)
+{
+    int rc;
+
+    rc = nv_linux_workqueue_flush_once();
+    if (rc != 0)
+        return rc;
+
+    return nv_linux_workqueue_flush_once();
+}
+
+int nv_linux_workqueue_shutdown(void)
+{
+    struct task_struct *thread;
+    unsigned long flags;
+    NvU64 generation;
+
+retry:
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    thread = nv_linux_workqueue_thread;
+    if (current == thread)
+    {
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        nv_printf(NV_DBG_ERRORS,
+                  "NVRM: nv_linux_workqueue_shutdown: called from worker thread\n");
+        return -EDEADLK;
+    }
+
+    if ((nv_linux_workqueue_state == NV_WQ_UNINITIALIZED) ||
+        (nv_linux_workqueue_state == NV_WQ_STOPPED))
+    {
+        nv_linux_workqueue_state = NV_WQ_STOPPED;
+        nv_linux_workqueue_thread = NULL;
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        wake_up_all(&nv_linux_workqueue_shutdown_wait);
+        return 0;
+    }
+
+    if (nv_linux_workqueue_state == NV_WQ_INITIALIZING)
+    {
+        generation = nv_linux_workqueue_generation;
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        wait_event(nv_linux_workqueue_shutdown_wait,
+            nv_linux_workqueue_initializing_done() ||
+            nv_linux_workqueue_generation_done(generation));
+        goto retry;
+    }
+
+    if ((nv_linux_workqueue_state == NV_WQ_DRAINING) ||
+        (nv_linux_workqueue_state == NV_WQ_STOPPING))
+    {
+        generation = nv_linux_workqueue_generation;
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        wait_event(nv_linux_workqueue_shutdown_wait,
+            nv_linux_workqueue_generation_done(generation));
+        return 0;
+    }
+
+    nv_linux_workqueue_state = NV_WQ_DRAINING;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    wake_up(&nv_linux_workqueue_worker_wait);
+
+    for (;;)
+    {
+        WARN_ON_ONCE(nv_linux_workqueue_flush() != 0);
+
+        spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+        /*
+         * The FIFO can be empty while the single worker is executing an item
+         * already removed from the list. Sequence equality covers work still
+         * queued, dequeued callbacks, callback body execution, queue-owned
+         * cleanup, and completion that has not yet been published.
+         */
+        if (list_empty(&nv_linux_workqueue_items) &&
+            (nv_linux_workqueue_completed_sequence ==
+             nv_linux_workqueue_next_sequence))
+        {
+            nv_linux_workqueue_state = NV_WQ_STOPPING;
+            thread = nv_linux_workqueue_thread;
+            spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+            break;
+        }
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+    }
+
+    if (thread != NULL)
+        kthread_stop(thread);
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    nv_linux_workqueue_thread = NULL;
+    nv_linux_workqueue_state = NV_WQ_STOPPED;
+    nv_linux_workqueue_generation++;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    wake_up_all(&nv_linux_workqueue_shutdown_wait);
+
+    return 0;
+}
