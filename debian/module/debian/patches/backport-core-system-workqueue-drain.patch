--- a/nvidia/nv.c
+++ b/nvidia/nv.c
@@ -43,6 +43,154 @@
 static NvU32 num_nv_devices = 0;
 NvU32 num_probed_nv_devices = 0;

+static DEFINE_SPINLOCK(nv_linux_workqueue_lock);
+static LIST_HEAD(nv_linux_workqueue_items);
+static DECLARE_WAIT_QUEUE_HEAD(nv_linux_workqueue_wait);
+static struct task_struct *nv_linux_workqueue_thread;
+static NvBool nv_linux_workqueue_stopping;
+static NvU64 nv_linux_workqueue_next_sequence;
+static NvU64 nv_linux_workqueue_completed_sequence;
+
+static int nv_linux_workqueue_main(void *arg)
+{
+    nv_work_t *work;
+    unsigned long flags;
+
+    while (!kthread_should_stop())
+    {
+        wait_event_interruptible(nv_linux_workqueue_wait,
+            kthread_should_stop() || !list_empty(&nv_linux_workqueue_items));
+
+        for (;;)
+        {
+            spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+            if (list_empty(&nv_linux_workqueue_items))
+            {
+                spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+                break;
+            }
+
+            work = list_first_entry(&nv_linux_workqueue_items,
+                                    nv_work_t, entry);
+            list_del_init(&work->entry);
+            work->running_sequence = work->queued_sequence;
+            work->queued = NV_FALSE;
+            work->running = NV_TRUE;
+            spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+#if (NV_INIT_WORK_ARGUMENT_COUNT == 2)
+            work->handler(work);
+#else
+            work->handler(work);
+#endif
+
+            spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+            work->running = NV_FALSE;
+            if (work->running_sequence > nv_linux_workqueue_completed_sequence)
+                nv_linux_workqueue_completed_sequence = work->running_sequence;
+            spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+            wake_up_all(&nv_linux_workqueue_wait);
+
+            if (work->dynamic)
+                os_free_mem((void *)work);
+        }
+    }
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    nv_linux_workqueue_stopping = NV_TRUE;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+    wake_up_all(&nv_linux_workqueue_wait);
+
+    return 0;
+}
+
+int nv_linux_workqueue_init(void)
+{
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    INIT_LIST_HEAD(&nv_linux_workqueue_items);
+    nv_linux_workqueue_stopping = NV_FALSE;
+    nv_linux_workqueue_next_sequence = 0;
+    nv_linux_workqueue_completed_sequence = 0;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    nv_linux_workqueue_thread = kthread_create_on_node(nv_linux_workqueue_main,
+                                                       NULL,
+                                                       NUMA_NO_NODE,
+                                                       "nvidia-wq");
+    if (IS_ERR(nv_linux_workqueue_thread))
+    {
+        int rc = PTR_ERR(nv_linux_workqueue_thread);
+
+        nv_linux_workqueue_thread = NULL;
+        spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+        nv_linux_workqueue_stopping = NV_TRUE;
+        spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+        return rc;
+    }
+
+    wake_up_process(nv_linux_workqueue_thread);
+    return 0;
+}
+
+int nv_linux_workqueue_schedule(nv_task_t *work)
+{
+    unsigned long flags;
+    int accepted = 0;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    if ((nv_linux_workqueue_thread != NULL) && !nv_linux_workqueue_stopping &&
+        !work->queued)
+    {
+        work->queued_sequence = ++nv_linux_workqueue_next_sequence;
+        list_add_tail(&work->entry, &nv_linux_workqueue_items);
+        work->queued = NV_TRUE;
+        accepted = 1;
+    }
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    if (accepted)
+        wake_up_process(nv_linux_workqueue_thread);
+
+    return accepted;
+}
+
+void nv_linux_workqueue_flush(void)
+{
+    NvU64 barrier;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    barrier = nv_linux_workqueue_next_sequence;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    wait_event(nv_linux_workqueue_wait,
+        nv_linux_workqueue_completed_sequence >= barrier);
+}
+
+void nv_linux_workqueue_shutdown(void)
+{
+    struct task_struct *thread;
+    unsigned long flags;
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    nv_linux_workqueue_stopping = NV_TRUE;
+    thread = nv_linux_workqueue_thread;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+
+    if (thread != NULL)
+    {
+        nv_linux_workqueue_flush();
+        kthread_stop(thread);
+    }
+
+    spin_lock_irqsave(&nv_linux_workqueue_lock, flags);
+    nv_linux_workqueue_thread = NULL;
+    spin_unlock_irqrestore(&nv_linux_workqueue_lock, flags);
+}
+
