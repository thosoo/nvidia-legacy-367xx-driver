Description: Drain only NVIDIA core work instead of flushing system workqueues
Author: OpenAI Codex
Forwarded: not-needed

--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -1636,9 +1636,44 @@ typedef struct nv_work_s {
     void *data;
 } nv_work_t;

-#define NV_WORKQUEUE_SCHEDULE(work) schedule_work(work)
-#define NV_WORKQUEUE_FLUSH()                           \
-    flush_scheduled_work();
+extern atomic_t nv_linux_workqueue_pending;
+extern wait_queue_head_t nv_linux_workqueue_wait;
+
+static inline int nv_linux_workqueue_schedule(nv_task_t *work)
+{
+    int ret;
+
+    /*
+     * Account before queueing so a concurrent flush cannot observe an
+     * accepted work item as idle. If schedule_work() rejects a duplicate
+     * pending item, immediately remove the speculative count.
+     */
+    atomic_inc(&nv_linux_workqueue_pending);
+    ret = schedule_work(work);
+    if (!ret)
+    {
+        if (atomic_dec_and_test(&nv_linux_workqueue_pending))
+            wake_up_all(&nv_linux_workqueue_wait);
+    }
+
+    return ret;
+}
+
+static inline void nv_linux_workqueue_complete(void)
+{
+    if (atomic_dec_and_test(&nv_linux_workqueue_pending))
+        wake_up_all(&nv_linux_workqueue_wait);
+}
+
+static inline void nv_linux_workqueue_flush(void)
+{
+    wait_event(nv_linux_workqueue_wait,
+               atomic_read(&nv_linux_workqueue_pending) == 0);
+}
+
+#define NV_WORKQUEUE_SCHEDULE(work) nv_linux_workqueue_schedule(work)
+#define NV_WORKQUEUE_COMPLETE() nv_linux_workqueue_complete()
+#define NV_WORKQUEUE_FLUSH() nv_linux_workqueue_flush()
