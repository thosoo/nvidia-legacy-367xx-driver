+ */
+#ifndef _NV_MMAP_LOCK_COMPAT_H_
+#define _NV_MMAP_LOCK_COMPAT_H_
+
+#include "conftest.h"
+#include <linux/mm.h>
+#include <linux/rwsem.h>
+
+static inline void nv_mmap_read_lock(struct mm_struct *mm)
+{
+#if defined(NV_MMAP_READ_LOCK_PRESENT)
+    mmap_read_lock(mm);
+#elif defined(NV_MM_HAS_MMAP_SEM)
+    down_read(&mm->mmap_sem);
+#else
+#error "No supported mmap read-lock API"
+#endif
+}
+
+static inline void nv_mmap_read_unlock(struct mm_struct *mm)
+{
+#if defined(NV_MMAP_READ_LOCK_PRESENT)
+    mmap_read_unlock(mm);
+#elif defined(NV_MM_HAS_MMAP_SEM)
+    up_read(&mm->mmap_sem);
+#else
+#error "No supported mmap read-unlock API"
+#endif
+}
+
+#endif /* _NV_MMAP_LOCK_COMPAT_H_ */
diff -Naur -x '*.orig' a/common/inc/nv-time-compat.h b/common/inc/nv-time-compat.h
--- a/common/inc/nv-time-compat.h	1970-01-01 00:00:00.000000000 +0000
+++ b/common/inc/nv-time-compat.h	2026-07-20 18:46:10.013166491 +0000
@@ -0,0 +1,41 @@
+/* _NVRM_COPYRIGHT_BEGIN_
+ *
+ * Copyright 2026 by NVIDIA Corporation.  All rights reserved.
+ *
+ * _NVRM_COPYRIGHT_END_
+ */
+#ifndef _NV_TIME_COMPAT_H_
+#define _NV_TIME_COMPAT_H_
+
+#include "conftest.h"
+#include "nvtypes.h"
+#include <linux/time.h>
+#include <linux/ktime.h>
+#include <linux/timekeeping.h>
+
+typedef struct
+{
+    time64_t tv_sec;
+    long tv_usec;
+} nv_timeval_t;
+
+static inline void nv_gettimeofday(nv_timeval_t *tv)
+{
+#if defined(NV_KTIME_GET_REAL_TS64_PRESENT)
+    struct timespec64 ts;
+
+    ktime_get_real_ts64(&ts);
+    tv->tv_sec = ts.tv_sec;
+    tv->tv_usec = ts.tv_nsec / NSEC_PER_USEC;
+#elif defined(NV_DO_GETTIMEOFDAY_PRESENT)
+    struct timeval legacy_tv;
+
+    do_gettimeofday(&legacy_tv);
+    tv->tv_sec = legacy_tv.tv_sec;
+    tv->tv_usec = legacy_tv.tv_usec;
+#else
+#error "No supported kernel wall-clock API"
+#endif
+}
+
+#endif /* _NV_TIME_COMPAT_H_ */
