Description: handle void-return SMP broadcast helpers
 Linux 5.3 changed on_each_cpu() to return void.  Probe return assignability
 for both NVIDIA SMP wrappers so legacy kernels keep real error returns while
 modern kernels return deterministic zero after performing the call.
Origin: backport, Debian 340xx 0008-on-each-cpu-5.3.patch and 390xx pattern
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh
+++ b/conftest.sh
@@ -2941,6 +2941,38 @@ compile_test() {
             compile_check_conftest "$CODE" "NV_TIMER_SETUP_PRESENT" "" "functions"
         ;;
+
+        on_each_cpu_returns_int)
+            CODE="
+            #include <linux/smp.h>
+
+            static void conftest_func(void *info) { }
+
+            int conftest_on_each_cpu_returns_int(void) {
+                int ret = on_each_cpu(conftest_func, NULL, 1);
+                return ret;
+            }"
+
+            compile_check_conftest "$CODE" "NV_ON_EACH_CPU_RETURNS_INT" "" "types"
+        ;;
+
+        smp_call_function_returns_int)
+            CODE="
+            #include <linux/smp.h>
+
+            static void conftest_func(void *info) { }
+
+            int conftest_smp_call_function_returns_int(void) {
+                int ret = smp_call_function(conftest_func, NULL, 1);
+                return ret;
+            }"
+
+            compile_check_conftest "$CODE" "NV_SMP_CALL_FUNCTION_RETURNS_INT" "" "types"
+        ;;
 
         # When adding a new conftest entry, please use the correct format for
--- a/nvidia/nvidia.Kbuild
+++ b/nvidia/nvidia.Kbuild
@@ -150,6 +150,8 @@ NV_CONFTEST_TYPE_COMPILE_TESTS += vm_ar
 NV_CONFTEST_TYPE_COMPILE_TESTS += vm_fault_has_address
 NV_CONFTEST_TYPE_COMPILE_TESTS += vm_fault_has_flags
 NV_CONFTEST_TYPE_COMPILE_TESTS += atomic64_type
+NV_CONFTEST_TYPE_COMPILE_TESTS += on_each_cpu_returns_int
+NV_CONFTEST_TYPE_COMPILE_TESTS += smp_call_function_returns_int
 
 NV_CONFTEST_GENERIC_COMPILE_TESTS += dom0_kernel_present
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -804,8 +804,28 @@ static inline void nv_iounmap(void *ptr,
 #define NV_SMP_CALL_FUNCTION(func, info, wait)               \
     ({                                                       \
         int __ret;                                           \
+#if defined(NV_SMP_CALL_FUNCTION_RETURNS_INT)                \
         __ret = smp_call_function(func, info, wait);          \
+#else                                                        \
+        smp_call_function(func, info, wait);                  \
+        __ret = 0;                                            \
+#endif                                                       \
         __ret;                                               \
     })
 
 #define NV_ON_EACH_CPU(func, info, wait)                     \
     ({                                                       \
         int __ret;                                           \
+#if defined(NV_ON_EACH_CPU_RETURNS_INT)                      \
         __ret = on_each_cpu(func, info, wait);                \
+#else                                                        \
+        on_each_cpu(func, info, wait);                        \
+        __ret = 0;                                            \
+#endif                                                       \
         __ret;                                               \
     })
