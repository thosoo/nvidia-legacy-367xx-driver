Description: handle void-return SMP broadcast helpers
 Linux 5.3 changed on_each_cpu() to return void.  Probe return assignability
 for both NVIDIA SMP wrappers so legacy kernels keep real error returns while
 modern kernels return deterministic zero after performing the call.
Origin: backport, Debian 340xx 0008-on-each-cpu-5.3.patch and 390xx pattern
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh	2026-07-20 08:48:00.950593756 +0000
+++ b/conftest.sh	2026-07-20 08:48:01.766580785 +0000
@@ -2957,6 +2957,34 @@
             compile_check_conftest "$CODE" "NV_VMALLOC_HAS_PGPROT_T_ARG" "" "types"
         ;;
 
+        on_each_cpu_returns_int)
+            CODE="
+            #include <linux/smp.h>
+
+            static void conftest_func(void *info) { }
+
+            int conftest_on_each_cpu_returns_int(void) {
+                int ret = on_each_cpu(conftest_func, NULL, 1);
+                return ret;
+            }"
+
+            compile_check_conftest "$CODE" "NV_ON_EACH_CPU_RETURNS_INT" "" "types"
+        ;;
+
+        smp_call_function_returns_int)
+            CODE="
+            #include <linux/smp.h>
+
+            static void conftest_func(void *info) { }
+
+            int conftest_smp_call_function_returns_int(void) {
+                int ret = smp_call_function(conftest_func, NULL, 1);
+                return ret;
+            }"
+
+            compile_check_conftest "$CODE" "NV_SMP_CALL_FUNCTION_RETURNS_INT" "" "types"
+        ;;
+
         # When adding a new conftest entry, please use the correct format for
         # specifying the relevant upstream Linux kernel commit.
         #
