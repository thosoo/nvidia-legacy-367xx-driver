--- a/common/inc/nv.h
+++ b/common/inc/nv.h
@@ -15,0 +16,2 @@
+#include "nvstatus.h"
+#include "nv-misc.h"
--- a/conftest.sh
+++ b/conftest.sh
@@ -316,0 +317,41 @@ procfs_compile_check_conftest() {
+dependency_barrier_compile_check_conftest() {
+    CODE="$1"
+    DEF="$2"
+    VAL="$3"
+    CAT="$4"
+    NAME=$(printf '%s' "$DEF" | tr 'A-Z' 'a-z')
+    DIAGDIR=conftest-dependency-barrier-diagnostics
+    SRC=conftest$$.c
+    OBJ=conftest$$.o
+    mkdir -p "$DIAGDIR"
+    rm -f "$OBJ"
+    echo "$CONFTEST_PREAMBLE
+    $CODE" > "$SRC"
+    printf '%s
+' "$CC" > "$DIAGDIR/$NAME.compiler.txt"
+    pwd > "$DIAGDIR/$NAME.cwd.txt"
+    cp "$SRC" "$DIAGDIR/$NAME.source.c"
+    printf '%s
+' "$CC $CFLAGS -Werror=implicit-function-declaration -Werror=incompatible-pointer-types -Werror=return-type -c $SRC" > "$DIAGDIR/$NAME.command.txt"
+    set +e
+    $CC $CFLAGS -Werror=implicit-function-declaration -Werror=incompatible-pointer-types -Werror=return-type -c "$SRC" > "$DIAGDIR/$NAME.stdout.txt" 2> "$DIAGDIR/$NAME.stderr.txt"
+    STATUS=$?
+    set -e
+    printf '%s
+' "$STATUS" > "$DIAGDIR/$NAME.exit.txt"
+    if [ "$STATUS" -eq 0 ] && [ -f "$OBJ" ]; then
+        echo yes > "$DIAGDIR/$NAME.object-created.txt"
+        rm -f "$OBJ"
+        echo "#define ${DEF} ${VAL}" | append_conftest "${CAT}"
+        echo "#define ${DEF} ${VAL}" > "$DIAGDIR/$NAME.definition.txt"
+        echo "smp_read_barrier_depends" > "$DIAGDIR/selected-implementation.txt"
+    else
+        echo no > "$DIAGDIR/$NAME.object-created.txt"
+        rm -f "$OBJ"
+        echo "#undef ${DEF}" | append_conftest "${CAT}"
+        echo "#undef ${DEF}" > "$DIAGDIR/$NAME.definition.txt"
+        echo "implicit dependency ordering" > "$DIAGDIR/selected-implementation.txt"
+    fi
+    rm -f "$SRC"
+}
+
@@ -1903,0 +1945,10 @@ compile_test() {
+        ;;
+
+        smp_read_barrier_depends)
+            CODE="
+            #include <asm/barrier.h>
+            void conftest_smp_read_barrier_depends(void)
+            {
+                smp_read_barrier_depends();
+            }"
+            dependency_barrier_compile_check_conftest "$CODE" "NV_SMP_READ_BARRIER_DEPENDS_PRESENT" "" "types"
