+static inline void uvm_read_dependency_barrier(void)
+{
+#if defined(NV_SMP_READ_BARRIER_DEPENDS_PRESENT)
+    smp_read_barrier_depends();
+#else
+    /*
+     * Linux removed smp_read_barrier_depends() after making dependency
+     * ordering implicit on supported architectures. This 367xx package is
