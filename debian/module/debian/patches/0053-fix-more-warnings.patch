From: Debian NVIDIA Maintainers
Subject: retain 367-relevant warning fixes from later packaging
Origin: Debian NVIDIA packaging warning-fix batch
Forwarded: not-needed

Rebased for NVIDIA 367.134.  The inherited batch also changed
nvidia/nv-gpu-numa.c, which is absent from 367.134; the dir_context.actor
return-type adaptation therefore cannot be applied to this branch without a
real target.  Retained hunks only affect files present in 367.134 and keep the
same warning-cleanup semantics.  The former nv-acpi.c unused-device hunk is
superseded by backport-acpi-api-compat.patch, which replaced the device-based
methods-uninit notifier path with handle-based notifier removal.
---
 nvidia-modeset/nvidia-modeset-linux.c | 1 +
  nvidia/nv-frontend.c                  | 3 ---
 nvidia/nv-frontend.h                  | 3 +++
 nvidia/nv-instance.c                  | 1 +
 nvidia/nv-mmap.c                      | 1 +
 5 files changed, 6 insertions(+), 3 deletions(-)

diff --git a/nvidia-modeset/nvidia-modeset-linux.c b/nvidia-modeset/nvidia-modeset-linux.c
--- a/nvidia-modeset/nvidia-modeset-linux.c
+++ b/nvidia-modeset/nvidia-modeset-linux.c
@@ -812,6 +812,7 @@ failed:
     return NULL;
 }
 
+static
 void NVKMS_API_CALL nvkms_close_common(struct nvkms_per_open *popen)
 {
     /*
diff --git a/nvidia/nv-frontend.c b/nvidia/nv-frontend.c
--- a/nvidia/nv-frontend.c
+++ b/nvidia/nv-frontend.c
@@ -40,9 +40,6 @@ nvidia_module_t *nv_minor_num_table[NV_FRONTEND_CONTROL_DEVICE_MINOR_MAX + 1];
 #if defined(CONFIG_PROC_FS)
 static struct proc_dir_entry *nv_proc_topdir;
 #endif
-#else
-int nvidia_init_module(void);
-void nvidia_exit_module(void);
 #endif
 
 /* EXPORTS to Linux Kernel */
diff --git a/nvidia/nv-frontend.h b/nvidia/nv-frontend.h
--- a/nvidia/nv-frontend.h
+++ b/nvidia/nv-frontend.h
@@ -31,4 +31,7 @@
