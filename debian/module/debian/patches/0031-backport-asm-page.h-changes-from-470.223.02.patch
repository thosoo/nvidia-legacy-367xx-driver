From 87c62d518fd5885c9330cc12a5d5a81c1a644940 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Wed, 1 Nov 2023 10:30:50 +0100
Subject: [PATCH] backport asm/page.h changes for 367.134
Origin: Debian nvidia-graphics-drivers 390-series packaging, rebased from the
 470.223.02 compatibility backport onto NVIDIA 367.134.
Description: Detect asm/page.h and include it before asm/set_memory.h in the
 367.134 set_pages_uc conftest, where newer headers require page definitions.

--- a/conftest.sh
+++ b/conftest.sh
@@ -118,6 +118,7 @@
     FILES="$FILES linux/sched/task_stack.h"
     FILES="$FILES xen/ioemu.h"
 
+    FILES_ARCH="$FILES_ARCH asm/page.h"
     FILES_ARCH="$FILES_ARCH asm/set_memory.h"
 
     translate_and_find_header_files $HEADERS      $FILES
@@ -367,6 +368,9 @@
             #
             CODE="
             #include <linux/types.h>
+            #if defined(NV_ASM_PAGE_H_PRESENT)
+            #include <asm/page.h>
+            #endif
             #if defined(NV_ASM_SET_MEMORY_H_PRESENT)
             #include <asm/set_memory.h>
             #else
@@ -385,6 +389,9 @@
             #
             CODE="
             #include <linux/types.h>
+            #if defined(NV_ASM_PAGE_H_PRESENT)
+            #include <asm/page.h>
+            #endif
             #if defined(NV_ASM_SET_MEMORY_H_PRESENT)
             #include <asm/set_memory.h>
             #else
@@ -419,6 +426,9 @@
             #
             CODE="
             #include <linux/types.h>
+            #if defined(NV_ASM_PAGE_H_PRESENT)
+            #include <asm/page.h>
+            #endif
             #if defined(NV_ASM_SET_MEMORY_H_PRESENT)
             #include <asm/set_memory.h>
             #else
