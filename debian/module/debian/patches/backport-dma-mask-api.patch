Description: replace removed pci_set_dma_mask with device DMA helper fallback
 Keep the 367.134 streaming DMA-mask semantics and return-code handling while
 compiling on kernels that no longer declare pci_set_dma_mask().
Origin: backport, NVIDIA 470.129.06 pci/dma compatibility direction
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh
+++ b/conftest.sh
@@ -2941,6 +2941,21 @@ compile_test() {
             compile_check_conftest "$CODE" "NV_TIMER_SETUP_PRESENT" "" "functions"
         ;;
+
+        pci_set_dma_mask)
+            CODE="
+            #include <linux/pci.h>
+
+            int conftest_pci_set_dma_mask(struct pci_dev *pdev, u64 mask)
+            {
+                return pci_set_dma_mask(pdev, mask);
+            }"
+
+            compile_check_conftest "$CODE" "NV_PCI_SET_DMA_MASK_PRESENT" "" "functions"
+        ;;
 
         # When adding a new conftest entry, please use the correct format for
--- a/nvidia/nvidia.Kbuild
+++ b/nvidia/nvidia.Kbuild
@@ -118,6 +118,7 @@ NV_CONFTEST_FUNCTION_COMPILE_TESTS += acpi_bus_get_device
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_domain_nr
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_dma_mapping_error
+NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_set_dma_mask
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg_alloc_table
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -1600,6 +1600,14 @@ static inline int nv_dma_maps_swiotlb(struct pci_dev *dev)
 #endif
 }
+
+static inline int nv_pci_set_dma_mask(struct pci_dev *pdev, u64 mask)
+{
+#if defined(NV_PCI_SET_DMA_MASK_PRESENT)
+    return pci_set_dma_mask(pdev, mask);
+#else
+    return dma_set_mask(&pdev->dev, mask);
+#endif
+}
--- a/nvidia/nv.c
+++ b/nvidia/nv.c
@@ -2291,7 +2291,7 @@ int nv_dma_configure(struct pci_dev *dev)
-    status = pci_set_dma_mask(dev, mask);
+    status = nv_pci_set_dma_mask(dev, mask);
     if (status != 0)
         return status;
