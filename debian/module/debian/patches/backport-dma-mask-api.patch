+++ b/nvidia/nvidia.Kbuild	2026-07-20 08:55:26.146935772 +0000
@@ -122,6 +122,7 @@
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_dma_mapping_error
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += acpi_fetch_acpi_dev
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += acpi_dev_for_each_child
+NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_set_dma_mask
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg_alloc_table
 #### Disabled for Debian legacy-367xx: no matching 367.134 conftest case.
 #NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg_init_table
--- a/common/inc/nv-linux.h	2026-07-20 08:55:26.034937618 +0000
+++ b/common/inc/nv-linux.h	2026-07-20 08:55:26.146935772 +0000
@@ -1485,6 +1485,15 @@
     return flags;
 }
 
+static inline int nv_pci_set_dma_mask(struct pci_dev *pdev, u64 mask)
+{
+#if defined(NV_PCI_SET_DMA_MASK_PRESENT)
+    return pci_set_dma_mask(pdev, mask);
+#else
+    return dma_set_mask(&pdev->dev, mask);
+#endif
+}
+
 static inline NvBool nv_dma_maps_swiotlb(struct pci_dev *dev)
 {
     NvBool swiotlb_in_use = NV_FALSE;
