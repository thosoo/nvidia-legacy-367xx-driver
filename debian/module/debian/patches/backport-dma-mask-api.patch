+#else
+    dma_unmap_sg(&pdev->dev, sgl, nents, NV_DMA_BIDIRECTIONAL);
+#endif
+}
+
+static inline int nv_dma_mapping_error(struct pci_dev *pdev, dma_addr_t addr)
+{
