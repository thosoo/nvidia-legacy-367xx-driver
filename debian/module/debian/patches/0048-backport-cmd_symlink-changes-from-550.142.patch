From afe70c7f39afc8f845a249017493b9de4d6741de Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Thu, 19 Dec 2024 13:42:55 +0100
Subject: [PATCH] backport cmd_symlink changes for 367.134
Origin: Debian nvidia-graphics-drivers 390-series packaging, rebased from the
 550.142 compatibility backport onto NVIDIA 367.134.
Description: Define the binary-object symlink command once in top-level Kbuild
 using an absolute source path, then remove duplicate per-module definitions.

--- a/Kbuild
+++ b/Kbuild
@@ -43,6 +43,13 @@
 # - Add any items that should always be built to $(always)
 #
 
+#
+# Create precompiled binary-object symlinks with an absolute target so Kbuild
+# works whether the external-module build CWD is the kernel tree or module tree.
+#
+quiet_cmd_symlink = SYMLINK $@
+ cmd_symlink = ln -sf $(abspath $<) $@
+
 always :=
 
 $(foreach _module, $(NV_KERNEL_MODULES), \
