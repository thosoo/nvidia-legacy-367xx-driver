+procfs_compile_check_conftest() {
+    CODE="$1"
+    DEF="$2"
+    VAL="$3"
+    CAT="$4"
+    NAME=$(printf '%s' "$DEF" | tr 'A-Z' 'a-z')
+    DIAGDIR=conftest-procfs-diagnostics
+    SRC=conftest$$.c
+    OBJ=conftest$$.o
+    mkdir -p "$DIAGDIR"
+    echo "$CONFTEST_PREAMBLE
+    $CODE" > "$SRC"
+    printf '%s\n' "$CC" > "$DIAGDIR/$NAME.compiler"
+    pwd > "$DIAGDIR/$NAME.cwd"
+    cp "$SRC" "$DIAGDIR/$NAME.source.c"
+    printf '%s\n' "$CC $CFLAGS -Werror=implicit-function-declaration -Werror=incompatible-pointer-types -c $SRC" > "$DIAGDIR/$NAME.command.txt"
+    set +e
+    $CC $CFLAGS -Werror=implicit-function-declaration -Werror=incompatible-pointer-types -c "$SRC" > "$DIAGDIR/$NAME.stdout" 2> "$DIAGDIR/$NAME.stderr"
+    STATUS=$?
+    set -e
+    printf '%s\n' "$STATUS" > "$DIAGDIR/$NAME.exit"
+    if [ -f "$OBJ" ]; then
+        echo yes > "$DIAGDIR/$NAME.object-created"
+        rm -f "$OBJ"
+        echo "#define ${DEF} ${VAL}" | append_conftest "${CAT}"
+        echo "#define ${DEF} ${VAL}" > "$DIAGDIR/$NAME.definition"
+        case "$DEF" in
+            NV_PROC_OPS_PRESENT)
+                echo "struct proc_ops" > "$DIAGDIR/selected-operation-table-type"
+            ;;
+            NV_PDE_DATA_LOWER_CASE_PRESENT)
+                echo "pde_data(inode)" > "$DIAGDIR/selected-private-data-accessor"
+            ;;
+            NV_PDE_DATA_UPPER_CASE_PRESENT)
+                test -f "$DIAGDIR/selected-private-data-accessor" || \
+                    echo "PDE_DATA(inode)" > "$DIAGDIR/selected-private-data-accessor"
+            ;;
+            NV_PDE_STRUCT_ACCESS_PRESENT)
+                test -f "$DIAGDIR/selected-private-data-accessor" || \
+                    echo "PDE(inode)->data" > "$DIAGDIR/selected-private-data-accessor"
+            ;;
+        esac
+    else
+        echo no > "$DIAGDIR/$NAME.object-created"
+        echo "#undef ${DEF}" | append_conftest "${CAT}"
+        echo "#undef ${DEF}" > "$DIAGDIR/$NAME.definition"
+        if [ "$DEF" = "NV_PROC_OPS_PRESENT" ]; then
+            echo "struct file_operations" > "$DIAGDIR/selected-operation-table-type"
+        fi
+    fi
+    rm -f "$SRC"
+}
