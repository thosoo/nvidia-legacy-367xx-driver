+                return PDE(inode)->data;
             }"
 
-            compile_check_conftest "$CODE" "NV_PDE_DATA_PRESENT" "" "functions"
+            procfs_compile_check_conftest "$CODE" "NV_PDE_STRUCT_ACCESS_PRESENT" "" "types"
         ;;
 
         get_num_physpages)
