+                return PDE_DATA(inode);
+            }"
+
+            procfs_compile_check_conftest "$CODE" "NV_PDE_DATA_UPPER_CASE_PRESENT" "" "functions"
+        ;;
+
+        pde_struct_access)
             #
-            # Determine if the PDE_DATA() function is present.
