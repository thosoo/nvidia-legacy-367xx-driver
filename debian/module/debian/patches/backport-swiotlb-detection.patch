Description: avoid private SWIOTLB global in nv_dma_maps_swiotlb
 The legacy global swiotlb is no longer public.  Use an exported public helper
 when the kernel provides one and otherwise conservatively report that the
 driver cannot prove SWIOTLB is active.
Origin: backport, later NVIDIA/Debian SWIOTLB public-helper direction
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh
+++ b/conftest.sh
@@ -2941,6 +2941,23 @@ compile_test() {
             compile_check_conftest "$CODE" "NV_TIMER_SETUP_PRESENT" "" "functions"
         ;;
+
+        is_swiotlb_active)
+            CODE="
+            #include <linux/device.h>
+            #include <linux/swiotlb.h>
+
+            int conftest_is_swiotlb_active(struct device *dev) {
+                return is_swiotlb_active(dev);
+            }"
+
+            compile_check_conftest "$CODE" "NV_IS_SWIOTLB_ACTIVE_PRESENT" "" "functions"
+        ;;
 
         # When adding a new conftest entry, please use the correct format for
--- a/nvidia/nvidia.Kbuild
+++ b/nvidia/nvidia.Kbuild
@@ -120,6 +120,7 @@ NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_get_domain_bus_and_slot
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += get_num_physpages
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += efi_enabled
+NV_CONFTEST_FUNCTION_COMPILE_TESTS += is_swiotlb_active
 
 NV_CONFTEST_TYPE_COMPILE_TESTS += acpi_op_remove
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -1512,7 +1512,12 @@ static inline int nv_dma_maps_swiotlb(st
 {
 #if defined(CONFIG_SWIOTLB)
+#if defined(NV_IS_SWIOTLB_ACTIVE_PRESENT)
+    return is_swiotlb_active(&dev->dev);
+#else
+    return 0;
+#endif
-    return (swiotlb == 1);
 #else
     return 0;
 #endif
 }
