+static struct acpi_device *nv_acpi_get_device(acpi_handle handle)
+{
+#if defined(NV_ACPI_FETCH_ACPI_DEV_PRESENT)
+    return acpi_fetch_acpi_dev(handle);
+#elif defined(NV_ACPI_BUS_GET_DEVICE_PRESENT)
+    struct acpi_device *device = NULL;
+
+    if (ACPI_FAILURE(acpi_bus_get_device(handle, &device)))
+        return NULL;
+
+    return device;
+#else
+    return NULL;
+#endif
+}
+
+static void nv_acpi_put_device(struct acpi_device *device)
+{
+#if defined(NV_ACPI_FETCH_ACPI_DEV_PRESENT)
+    if (device != NULL)
+        put_device(&device->dev);
+#endif
+}
+
+#if defined(NV_ACPI_DEV_FOR_EACH_CHILD_PRESENT)
+struct nv_acpi_add_child_data
+{
+    nv_acpi_t *object;
+    int count;
+};
+
+static int nv_acpi_add_one_child(struct acpi_device *dev, void *data)
+{
+    struct nv_acpi_add_child_data *child_data = data;
+    nv_acpi_integer_t device_id = 0;
+    acpi_status status;
+
+    if (child_data->count == NV_MAXNUM_DISPLAY_DEVICES)
+    {
+        nv_printf(NV_DBG_ERRORS,
+                  "NVRM: nv_acpi_add: Total number of devices cannot exceed %d\n",
+                  NV_MAXNUM_DISPLAY_DEVICES);
+        return 1;
+    }
+
+    status = acpi_evaluate_integer(dev->handle, "_ADR", NULL, &device_id);
+    if (ACPI_FAILURE(status))
+        return 0;
+
+    device_id = (device_id & 0xffff);
+
+    if ((device_id != 0x100) &&
+        (device_id != 0x200) &&
+        (device_id != 0x0110) && (device_id != 0x0118) && (device_id != 0x0400) &&
+        (device_id != 0x0111) && (device_id != 0x0120) && (device_id != 0x0300))
+    {
+        child_data->object->default_display_mask = 1;
+        return 1;
+    }
+
+    child_data->object->pNvVideo[child_data->count].dev_id = device_id;
+    child_data->object->pNvVideo[child_data->count].dev_handle = dev->handle;
+    child_data->count++;
+
+    return 0;
+}
+
+struct nv_acpi_ddc_child_data
+{
+    acpi_handle lcd_dev_handle;
+};
+
+static int nv_acpi_find_lcd_child(struct acpi_device *dev, void *data)
+{
+    struct nv_acpi_ddc_child_data *child_data = data;
+    nv_acpi_integer_t device_id = 0;
+    acpi_status status;
+
+    status = acpi_evaluate_integer(dev->handle, "_ADR", NULL, &device_id);
+    if (ACPI_FAILURE(status))
+        return 0;
+
+    device_id = (device_id & 0xffff);
+
+    if ((device_id == 0x0110) || (device_id == 0x0118) || (device_id == 0x0400))
+    {
+        child_data->lcd_dev_handle = dev->handle;
+        nv_printf(NV_DBG_INFO, "NVRM: %s Found LCD: %x\n", __FUNCTION__, device_id);
+        return 1;
+    }
+
+    return 0;
+}
+#endif
