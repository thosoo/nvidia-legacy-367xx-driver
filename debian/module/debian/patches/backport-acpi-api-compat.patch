+static NV_STATUS nv_install_notifier_handle(acpi_handle handle, acpi_notify_handler handler)
+{
+    nvidia_stack_t *sp = NULL;
+    nv_acpi_t *pNvAcpiObject = NULL;
+    NV_STATUS rmStatus;
+    acpi_status status;
+
+    if (!handle || nvif_notify_object)
+        return NV_ERR_GENERIC;
+
+    if (nv_kmem_cache_alloc_stack(&sp) != 0)
+        return NV_ERR_NO_MEMORY;
+
+    rmStatus = os_alloc_mem((void **) &pNvAcpiObject, sizeof(nv_acpi_t));
+    if (rmStatus != NV_OK)
+        goto return_error;
+
+    os_mem_set((void *)pNvAcpiObject, 0, sizeof(nv_acpi_t));
+    pNvAcpiObject->sp = sp;
+
+    status = acpi_install_notify_handler(handle, ACPI_DEVICE_NOTIFY,
+              handler, pNvAcpiObject);
+    if (!ACPI_FAILURE(status))
+    {
+        pNvAcpiObject->notify_handler_installed = 1;
+        nvif_notify_object = pNvAcpiObject;
+        return NV_OK;
+    }
+
+return_error:
+    nv_kmem_cache_free_stack(sp);
+    if (pNvAcpiObject)
+        os_free_mem((void *)pNvAcpiObject);
+    return NV_ERR_GENERIC;
+}
+
+static void nv_uninstall_notifier_handle(acpi_handle handle, acpi_notify_handler handler)
+{
+    acpi_status status;
+    nv_acpi_t *pNvAcpiObject = nvif_notify_object;
+
+    if (!handle || !pNvAcpiObject)
+        return;
+
+    if (pNvAcpiObject->notify_handler_installed)
+    {
+        status = acpi_remove_notify_handler(handle, ACPI_DEVICE_NOTIFY, handler);
+        if (ACPI_FAILURE(status))
+        {
+            nv_printf(NV_DBG_INFO,
+                "NVRM: nv_acpi_methods_uninit: failed to remove event notification handler (%d)!\n", status);
+            return;
+        }
+    }
+
+    nv_kmem_cache_free_stack(pNvAcpiObject->sp);
+    os_free_mem((void *)pNvAcpiObject);
+    nvif_notify_object = NULL;
+}
