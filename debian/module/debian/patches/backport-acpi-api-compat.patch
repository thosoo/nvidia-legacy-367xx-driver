+struct nv_acpi_child_walk_data
+{
+    nv_acpi_t *object;
+    int count;
+    acpi_handle lcd_dev_handle;
+};
+
+static acpi_status nv_acpi_add_one_child_handle(
+    acpi_handle handle,
+    u32 nest_level,
+    void *context,
+    void **return_value
+)
+{
+    struct nv_acpi_child_walk_data *child_data = context;
+    nv_acpi_integer_t device_id = 0;
+    acpi_status status;
+
+    status = acpi_evaluate_integer(handle, "_ADR", NULL, &device_id);
+    if (ACPI_FAILURE(status))
+        return AE_OK;
+
+    device_id = (device_id & 0xffff);
+
+    if (child_data->count == NV_MAXNUM_DISPLAY_DEVICES)
+    {
+        nv_printf(NV_DBG_ERRORS,
+                  "NVRM: nv_acpi_add: Total number of devices cannot exceed %d\n",
+                  NV_MAXNUM_DISPLAY_DEVICES);
+        return AE_CTRL_TERMINATE;
+    }
+
+    if ((device_id != 0x100) &&
+        (device_id != 0x200) &&
+        (device_id != 0x0110) && (device_id != 0x0118) && (device_id != 0x0400) &&
+        (device_id != 0x0111) && (device_id != 0x0120) && (device_id != 0x0300))
+    {
+        child_data->object->default_display_mask = 1;
+        return AE_CTRL_TERMINATE;
+    }
+
+    child_data->object->pNvVideo[child_data->count].dev_id = device_id;
+    child_data->object->pNvVideo[child_data->count].dev_handle = handle;
+    child_data->count++;
+
+    return AE_OK;
+}
+
+static acpi_status nv_acpi_find_lcd_child_handle(
+    acpi_handle handle,
+    u32 nest_level,
+    void *context,
+    void **return_value
+)
+{
+    struct nv_acpi_child_walk_data *child_data = context;
+    nv_acpi_integer_t device_id = 0;
+    acpi_status status;
+
+    status = acpi_evaluate_integer(handle, "_ADR", NULL, &device_id);
+    if (ACPI_FAILURE(status))
+        return AE_OK;
+
+    device_id = (device_id & 0xffff);
+
+    if ((device_id == 0x0110) || (device_id == 0x0118) || (device_id == 0x0400))
+    {
+        child_data->lcd_dev_handle = handle;
+        nv_printf(NV_DBG_INFO, "NVRM: %s Found LCD: %x\n", __FUNCTION__, device_id);
+        return AE_CTRL_TERMINATE;
+    }
+
+    return AE_OK;
+}
