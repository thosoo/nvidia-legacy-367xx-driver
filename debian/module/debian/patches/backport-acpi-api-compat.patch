Description: use public ACPI device helpers on modern kernels
 Replace direct struct acpi_device child list/member traversal and removed
 acpi_bus_get_device() assumptions with reference-managed helper wrappers.
Origin: backport, NVIDIA 470+ ACPI compatibility design adapted to 367.134
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh	2026-07-20 07:26:06.236222698 +0000
+++ b/conftest.sh	2026-07-20 07:26:06.308222581 +0000
@@ -2994,6 +2994,35 @@
             compile_check_conftest "$CODE" "NV_IS_SWIOTLB_ACTIVE_PRESENT" "" "functions"
         ;;
 
+        acpi_fetch_acpi_dev)
+            CODE="
+            #include <linux/acpi.h>
+
+            struct acpi_device *conftest_acpi_fetch_acpi_dev(acpi_handle handle)
+            {
+                return acpi_fetch_acpi_dev(handle);
+            }"
+
+            compile_check_conftest "$CODE" "NV_ACPI_FETCH_ACPI_DEV_PRESENT" "" "functions"
+        ;;
+
+        acpi_dev_for_each_child)
+            CODE="
+            #include <linux/acpi.h>
+
+            static int conftest_child(struct acpi_device *adev, void *data)
+            {
+                return 0;
+            }
+
+            int conftest_acpi_dev_for_each_child(struct acpi_device *adev)
+            {
+                return acpi_dev_for_each_child(adev, conftest_child, NULL);
+            }"
+
+            compile_check_conftest "$CODE" "NV_ACPI_DEV_FOR_EACH_CHILD_PRESENT" "" "functions"
+        ;;
+
         # When adding a new conftest entry, please use the correct format for
         # specifying the relevant upstream Linux kernel commit.
         #
