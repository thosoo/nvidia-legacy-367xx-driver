Description: fix sg allocation conftest false negatives
 Probe the actual exported scatterlist allocation calls with the headers and
 argument lists consumed by 367.134.
Origin: vendor, Debian 340xx/390xx conftest pattern adapted to 367.134
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh	2026-07-20 07:26:06.144222847 +0000
+++ b/conftest.sh	2026-07-20 07:26:06.236222698 +0000
@@ -1320,37 +1320,34 @@
 
         sg_alloc_table)
             #
-            # Determine if include/linux/scatterlist.h exists and which table
-            # allocation functions are present if so.
+            # Determine if the scatterlist allocation functions are present
+            # using the exact prototypes consumed by the 367.134 DMA helpers.
             #
-            echo "$CONFTEST_PREAMBLE
-            #include <linux/scatterlist.h>
-            int conftest_sg_alloc_table(void) {
-            }" > conftest$$.c
-
-            $CC $CFLAGS -c conftest$$.c > /dev/null 2>&1
-            rm -f conftest$$.c
-
-            if [ ! -f conftest$$.o ]; then
-                echo "#undef NV_SG_ALLOC_TABLE_PRESENT" | append_conftest "functions"
-                echo "#undef NV_SG_ALLOC_TABLE_FROM_PAGES_PRESENT" | append_conftest "functions"
-                return
-            fi
-            
-            rm -f conftest$$.o
-
             CODE="
             #include <linux/scatterlist.h>
-            int conftest_sg_alloc_table(void) {
-                sg_alloc_table();
+
+            int conftest_sg_alloc_table(struct sg_table *table,
+                                        unsigned int nents,
+                                        gfp_t gfp)
+            {
+                return sg_alloc_table(table, nents, gfp);
             }"
 
             compile_check_conftest "$CODE" "NV_SG_ALLOC_TABLE_PRESENT" "" "functions"
 
             CODE="
+            #include <linux/mm.h>
             #include <linux/scatterlist.h>
-            void conftest_sg_alloc_table_from_pages(void) {
-                sg_alloc_table_from_pages();
+
+            int conftest_sg_alloc_table_from_pages(struct sg_table *table,
+                                                   struct page **pages,
+                                                   unsigned int n_pages,
+                                                   unsigned int offset,
+                                                   unsigned long size,
+                                                   gfp_t gfp)
+            {
+                return sg_alloc_table_from_pages(table, pages, n_pages,
+                                                 offset, size, gfp);
             }"
 
             compile_check_conftest "$CODE" "NV_SG_ALLOC_TABLE_FROM_PAGES_PRESENT" "" "functions"
