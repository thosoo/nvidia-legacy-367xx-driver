Description: fix sg allocation conftest false negatives
 Probe the actual exported scatterlist allocation calls with the headers and
 argument lists consumed by 367.134.
Origin: vendor, Debian 340xx/390xx conftest pattern adapted to 367.134
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh
+++ b/conftest.sh
@@ -2800,6 +2800,47 @@ compile_test() {
             compile_check_conftest "$CODE" "NV_PCI_DMA_MAPPING_ERROR_PRESENT" "" "functions"
         ;;
+
+        sg_alloc_table)
+            CODE="
+            #include <linux/scatterlist.h>
+
+            int conftest_sg_alloc_table(struct sg_table *table,
+                                        unsigned int nents,
+                                        gfp_t gfp)
+            {
+                return sg_alloc_table(table, nents, gfp);
+            }"
+
+            compile_check_conftest "$CODE" "NV_SG_ALLOC_TABLE_PRESENT" "" "functions"
+        ;;
+
+        sg_alloc_table_from_pages)
+            CODE="
+            #include <linux/mm.h>
+            #include <linux/scatterlist.h>
+
+            int conftest_sg_alloc_table_from_pages(struct sg_table *table,
+                                                   struct page **pages,
+                                                   unsigned int n_pages,
+                                                   unsigned int offset,
+                                                   unsigned long size,
+                                                   gfp_t gfp)
+            {
+                return sg_alloc_table_from_pages(table, pages, n_pages,
+                                                 offset, size, gfp);
+            }"
+
+            compile_check_conftest "$CODE" "NV_SG_ALLOC_TABLE_FROM_PAGES_PRESENT" "" "functions"
+        ;;
 
         pci_get_domain_bus_and_slot)
             CODE="
--- a/nvidia/nvidia.Kbuild
+++ b/nvidia/nvidia.Kbuild
@@ -120,6 +120,7 @@ NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_dma_mapping_error
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg_alloc_table
+NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg_alloc_table_from_pages
 #### Disabled for Debian legacy-367xx: no matching 367.134 conftest case.
 #NV_CONFTEST_FUNCTION_COMPILE_TESTS += sg_init_table
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += pci_get_domain_bus_and_slot
