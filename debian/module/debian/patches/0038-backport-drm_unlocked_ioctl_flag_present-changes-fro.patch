From 20b07eda8f43c7dd352b32b3f12e79eb92e2e934 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Mon, 4 Mar 2024 13:50:23 +0100
Subject: [PATCH] backport drm_unlocked_ioctl_flag_present changes for 367.134
Origin: Debian nvidia-graphics-drivers 390-series packaging, rebased from the
 470.239.06 compatibility backport onto NVIDIA 367.134.
Description: NVIDIA 367.134 passes DRM_UNLOCKED directly in its ioctl table and
 does not ship the later nvidia-drm-helper.h compatibility header. Define the
 removed flag locally in nvidia-drm-drv.c instead of adding an unused conftest
 or fabricating the later-driver helper header.

--- a/nvidia-drm/nvidia-drm-drv.c
+++ b/nvidia-drm/nvidia-drm-drv.c
@@ -39,6 +39,15 @@
 
 #include <drm/drm_crtc_helper.h>
 
+/*
+ * DRM_UNLOCKED was removed after becoming implicit for non-legacy DRM driver
+ * ioctls. NVIDIA 367.134 passes it directly in nv_drm_ioctls, so define it as
+ * zero when newer kernel headers no longer provide the flag.
+ */
+#ifndef DRM_UNLOCKED
+#define DRM_UNLOCKED 0
+#endif
+
 #if defined(NV_DRM_DRM_GEM_H_PRESENT)
 #include <drm/drm_gem.h>
 #endif
