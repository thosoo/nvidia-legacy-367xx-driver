From c0557d49b7076338a8fe12f1a8d68fff45a76c08 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Wed, 31 May 2023 12:25:55 +0200
Subject: [PATCH 2/2] backport vm_area_struct_has_const_vm_flags changes for 367.134 UVM
Origin: Debian nvidia-graphics-drivers 390-series packaging, rebased from the
 525.105.17 compatibility backport onto NVIDIA 367.134.
Description: Reuse the core nv_vm_flags_set() helper for the UVM mmap path and
 request the matching conftest in the older 367.134 UVM Kbuild list.

--- a/nvidia-uvm/nvidia-uvm.Kbuild
+++ b/nvidia-uvm/nvidia-uvm.Kbuild
@@ -139,3 +139,4 @@
 NV_CONFTEST_TYPE_COMPILE_TESTS += vm_fault_present
 NV_CONFTEST_TYPE_COMPILE_TESTS += vm_ops_fault_removed_vma_arg
 NV_CONFTEST_TYPE_COMPILE_TESTS += kref_read
+NV_CONFTEST_TYPE_COMPILE_TESTS += vm_area_struct_has_const_vm_flags
--- a/nvidia-uvm/uvm8.c
+++ b/nvidia-uvm/uvm8.c
@@ -572,7 +572,7 @@
     // Using VM_DONTCOPY would be nice, but madvise(MADV_DOFORK) can reset that
     // so we have to handle vm_open on fork anyway. We could disable MADV_DOFORK
     // with VM_IO, but that causes other mapping issues.
-    vma->vm_flags |= VM_MIXEDMAP | VM_DONTEXPAND;
+    nv_vm_flags_set(vma, VM_MIXEDMAP | VM_DONTEXPAND);
 
     vma->vm_ops = &uvm_vm_ops_managed;
 
