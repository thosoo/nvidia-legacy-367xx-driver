From df6b55bb77ad479fcbcbcdaffd756369ed9dc4fb Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Wed, 1 Nov 2023 10:31:40 +0100
Subject: [PATCH] backport drm_gem_prime_handle_to_fd changes for 367.134
Origin: Debian nvidia-graphics-drivers 390-series packaging, rebased from the
 470.223.02 compatibility backport onto NVIDIA 367.134.
Description: Guard the 367.134 PRIME handle-to-fd callback on kernels where
 drm_gem_prime_handle_to_fd is no longer exported.

--- a/nvidia-drm/nvidia-drm-drv.c
+++ b/nvidia-drm/nvidia-drm-drv.c
@@ -614,7 +614,14 @@
     .ioctls                 = nv_drm_ioctls,
     .num_ioctls             = ARRAY_SIZE(nv_drm_ioctls),
 
+/*
+ * linux-next commit 71a7974ac701 ("drm/prime: Unexport helpers for fd/handle
+ * conversion") unexports drm_gem_prime_handle_to_fd(). If the symbol is not
+ * present, leave the callback unset so DRM core defaults apply.
+ */
+#if NV_IS_EXPORT_SYMBOL_PRESENT_drm_gem_prime_handle_to_fd
     .prime_handle_to_fd     = drm_gem_prime_handle_to_fd,
+#endif
     .gem_prime_export       = nvidia_drm_gem_prime_export,
     .gem_prime_get_sg_table = nvidia_drm_gem_prime_get_sg_table,
     .gem_prime_vmap         = nvidia_drm_gem_prime_vmap,
--- a/nvidia-drm/nvidia-drm.Kbuild
+++ b/nvidia-drm/nvidia-drm.Kbuild
@@ -49,6 +49,8 @@
 NV_CONFTEST_GENERIC_COMPILE_TESTS += drm_available
 NV_CONFTEST_GENERIC_COMPILE_TESTS += drm_atomic_available
 
+NV_CONFTEST_SYMBOL_COMPILE_TESTS += is_export_symbol_present_drm_gem_prime_handle_to_fd
+
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += drm_dev_unref
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += remap_pfn_range
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += drm_reinit_primary_mode_group
