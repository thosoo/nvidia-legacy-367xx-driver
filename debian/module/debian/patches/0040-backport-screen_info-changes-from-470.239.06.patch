From 912ee3fa14aa296c653bd5aa8bac77721960e736 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Mon, 4 Mar 2024 22:48:44 +0100
Subject: [PATCH] backport screen_info export checks for 367.134
Origin: Debian nvidia-graphics-drivers 390-series packaging, rebased from the
 470.239.06 compatibility backport onto NVIDIA 367.134.
Description: Keep the existing Module.symvers export regex fixes and add the
 367.134 nv-linux.h helper plus nvidia.Kbuild request needed to test whether
 screen_info is usable from the non-GPL module.

--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -2007,4 +2007,6 @@
     return NV_FALSE;
 }
 
+#define NV_CHECK_EXPORT_SYMBOL(symbol)  (NV_IS_EXPORT_SYMBOL_PRESENT_##symbol && \
+                                         !NV_IS_EXPORT_SYMBOL_GPL_##symbol)
 #endif  /* _NV_LINUX_H_ */
--- a/nvidia/nvidia.Kbuild
+++ b/nvidia/nvidia.Kbuild
@@ -144,6 +144,7 @@
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += cpuhp_setup_state
 NV_CONFTEST_FUNCTION_COMPILE_TESTS += timer_setup
 NV_CONFTEST_SYMBOL_COMPILE_TESTS += is_export_symbol_present_swiotlb_map_sg_attrs
+NV_CONFTEST_SYMBOL_COMPILE_TESTS += is_export_symbol_gpl_screen_info
 
 NV_CONFTEST_TYPE_COMPILE_TESTS += i2c_adapter
 NV_CONFTEST_TYPE_COMPILE_TESTS += pm_message_t
