Description: backport nv_vmalloc __vmalloc signature detection from 450.57
 Linux 5.8 removed the pgprot_t argument from __vmalloc().  Probe the
 callable prototype instead of selecting by kernel version.
Origin: backport, NVIDIA 450.57 nv_vmalloc compatibility pattern
Forwarded: not-needed
Last-Update: 2026-07-20

--- a/conftest.sh
+++ b/conftest.sh
@@ -2941,6 +2941,24 @@ compile_test() {
             compile_check_conftest "$CODE" "NV_TIMER_SETUP_PRESENT" "" "functions"
         ;;
+
+        vmalloc_has_pgprot_t_arg)
+            CODE="
+            #include <linux/vmalloc.h>
+            #include <linux/gfp.h>
+            #include <asm/pgtable.h>
+
+            void conftest_vmalloc_has_pgprot_t_arg(void) {
+                (void)__vmalloc(4096, GFP_KERNEL, PAGE_KERNEL);
+            }"
+
+            compile_check_conftest "$CODE" "NV_VMALLOC_HAS_PGPROT_T_ARG" "" "types"
+        ;;
 
         # When adding a new conftest entry, please use the correct format for
         # specifying the relevant upstream Linux kernel commit.
--- a/nvidia/nvidia.Kbuild
+++ b/nvidia/nvidia.Kbuild
@@ -150,6 +150,7 @@ NV_CONFTEST_TYPE_COMPILE_TESTS += vm_ar
 NV_CONFTEST_TYPE_COMPILE_TESTS += vm_fault_has_address
 NV_CONFTEST_TYPE_COMPILE_TESTS += vm_fault_has_flags
 NV_CONFTEST_TYPE_COMPILE_TESTS += atomic64_type
+NV_CONFTEST_TYPE_COMPILE_TESTS += vmalloc_has_pgprot_t_arg
 
 NV_CONFTEST_GENERIC_COMPILE_TESTS += dom0_kernel_present
 NV_CONFTEST_GENERIC_COMPILE_TESTS += nvidia_vgpu_kvm_build
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -666,7 +666,11 @@ static inline void *nv_vmalloc(unsigned
 {
     void *ptr;
 
+#if defined(NV_VMALLOC_HAS_PGPROT_T_ARG)
     ptr = __vmalloc(size, GFP_KERNEL, PAGE_KERNEL);
+#else
+    ptr = __vmalloc(size, GFP_KERNEL);
+#endif
     if (ptr)
         NV_MEMDBG_ADD(ptr, size);
 
