From 454a2bc8fc4416f16d956120ee5e54b3770dd5c9 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Sun, 8 Dec 2024 03:20:30 +0100
Subject: [PATCH] backport warning fixes from 535.216.01

---
 common/inc/nv-linux.h                 | 12 ++++++++++++
 nvidia-modeset/nvidia-modeset-linux.c |  3 ++-
 nvidia/nv-kthread-q-selftest.c        |  2 +-
 nvidia/nv-dma.c                       |  2 +-
 nvidia/nv-ibmnpu.c                    |  2 +-
 nvidia/nv-mmap.c                      |  4 ++--
 nvidia/nv-procfs.c                    |  2 +-
 nvidia/nvlink_linux.c                 |  1 +
 8 files changed, 21 insertions(+), 7 deletions(-)

diff --git a/common/inc/nv-linux.h b/common/inc/nv-linux.h
index 2bb311c8..6c6b9eda 100644
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -540,7 +540,9 @@ static inline void *nv_vmalloc(unsigned long size)
     void *ptr = __vmalloc(size, GFP_KERNEL);
 #endif
     if (ptr)
+    {
         NV_MEMDBG_ADD(ptr, size);
+    }
     return ptr;
 }
 
@@ -554,7 +556,9 @@ static inline void *nv_ioremap(NvU64 phys, NvU64 size)
 {
     void *ptr = ioremap(phys, size);
     if (ptr)
+    {
         NV_MEMDBG_ADD(ptr, size);
+    }
     return ptr;
 }
 
@@ -566,7 +570,9 @@ static inline void *nv_ioremap_nocache(NvU64 phys, NvU64 size)
     void *ptr = ioremap(phys, size);
 #endif
     if (ptr)
+    {
         NV_MEMDBG_ADD(ptr, size);
+    }
     return ptr;
 }
 
@@ -575,7 +581,9 @@ static inline void *nv_ioremap_cache(NvU64 phys, NvU64 size)
 #if defined(NV_IOREMAP_CACHE_PRESENT)
     void *ptr = ioremap_cache(phys, size);
     if (ptr)
+    {
         NV_MEMDBG_ADD(ptr, size);
+    }
     return ptr;
 #else
     return nv_ioremap(phys, size);
@@ -587,7 +595,9 @@ static inline void *nv_ioremap_wc(NvU64 phys, NvU64 size)
 #if defined(NV_IOREMAP_WC_PRESENT)
     void *ptr = ioremap_wc(phys, size);
     if (ptr)
+    {
         NV_MEMDBG_ADD(ptr, size);
+    }
     return ptr;
 #else
     return nv_ioremap_nocache(phys, size);
@@ -652,7 +662,9 @@ static inline NvUPtr nv_vmap(struct page **pages, NvU32 page_count,
     /* All memory cached in PPC64LE; can't honor 'cached' input. */
     ptr = vmap(pages, page_count, VM_MAP, prot);
     if (ptr)
+    {
         NV_MEMDBG_ADD(ptr, page_count * PAGE_SIZE);
+    }
     return (NvUPtr)ptr;
 }
 
