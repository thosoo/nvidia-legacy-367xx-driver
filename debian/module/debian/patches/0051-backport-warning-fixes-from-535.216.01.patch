From: Debian NVIDIA Maintainers
Subject: backport 367-relevant warning fixes from 535.216.01
Origin: Debian nvidia-graphics-drivers 535.216.01 packaging
Forwarded: not-needed

Rebased for NVIDIA 367.134.  The inherited patch also touched later or
non-amd64-only files absent from the 367.134 kernel tree
(nvidia/nv-kthread-q-selftest.c and nvidia/nv-ibmnpu.c) and added an
include already present in 367.134 nvidia/nvlink_linux.c.  This retains
only local static conversions whose symbols have no cross-translation-unit
callers in the 367.134 source tree.
---
 nvidia-modeset/nvidia-modeset-linux.c | 3 ++-
 nvidia/nv-dma.c                       | 2 +-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/nvidia-modeset/nvidia-modeset-linux.c b/nvidia-modeset/nvidia-modeset-linux.c
--- a/nvidia-modeset/nvidia-modeset-linux.c
+++ b/nvidia-modeset/nvidia-modeset-linux.c
@@ -759,7 +759,7 @@ static void nvkms_kapi_event_kthread_q_callback(nv_kthread_q_item_t *work)
     nvKmsKapiHandleEventQueueChange(work->device);
 }
 
-struct nvkms_per_open *nvkms_open_common(enum NvKmsClientType type,
+static struct nvkms_per_open *nvkms_open_common(enum NvKmsClientType type,
                                          struct NvKmsKapiDevice *device,
                                          int *status)
 {
@@ -850,6 +850,7 @@ void NVKMS_API_CALL nvkms_close_common(struct nvkms_per_open *popen)
     nvkms_free(popen, sizeof(*popen));
 }
 
+static
 int NVKMS_API_CALL nvkms_ioctl_common
 (
     struct nvkms_per_open *popen,
diff --git a/nvidia/nv-dma.c b/nvidia/nv-dma.c
--- a/nvidia/nv-dma.c
+++ b/nvidia/nv-dma.c
@@ -221,7 +221,7 @@ void nv_destroy_dma_map_scatterlist(nv_dma_map_t *dma_map)
     os_free_mem(dma_map->mapping.discontig.submaps);
 }
 
-void nv_load_dma_map_scatterlist(
+static void nv_load_dma_map_scatterlist(
     nv_dma_map_t *dma_map,
     NvU64 *va_array
 )
